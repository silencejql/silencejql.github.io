.Start();</span><br><span class="line">        <span class="keyword">while</span> (<span class="literal">true</span>)</span><br><span class="line">        &#123;</span><br><span class="line">            <span class="keyword">try</span></span><br><span class="line">            &#123;</span><br><span class="line">                <span class="comment">//开始异步操作，接受远程客户端连入</span></span><br><span class="line">                IAsyncResult ir = listener.BeginAcceptTcpClient(AcceptCallBack, listener);</span><br><span class="line">                <span class="keyword">while</span> (ir.IsCompleted != <span class="literal">true</span>)</span><br><span class="line">                &#123;</span><br><span class="line">                    Thread.Sleep(<span class="number">10</span>);</span><br><span class="line">                &#125;</span><br><span class="line">            &#125;</span><br><span class="line">            <span class="keyword">catch</span> (Exception e)</span><br><span class="line">            &#123;</span><br><span class="line">                DebugException(e.Message[<span class="number">0</span>].ToString());</span><br><span class="line">            &#125;</span><br><span class="line">        &#125;</span><br><span class="line">    &#125;);</span><br><span class="line">&#125;</span><br><span class="line"><span class="comment">//处理异常的方法</span></span><br><span class="line"><span class="function"><span class="keyword">public</span> <span class="keyword">void</span> <span class="title">DebugException</span>(<span class="params"><span class="built_in">string</span> log</span>)</span></span><br><span class="line">&#123;</span><br><span class="line">    Action&lt;<span class="built_in">string</span>&gt; act = UpdateMsgBox;</span><br><span class="line">    <span class="keyword">this</span>.Invoke(act, <span class="string">&quot;出现异常情况&quot;</span>);</span><br><span class="line">    <span class="keyword">this</span>.Invoke(act, <span class="string">&quot;原因: &quot;</span>